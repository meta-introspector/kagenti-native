{
  "name": "kiro-feed-uucp",
  "namespace": "zone42",
  "nixPackage": "path:///mnt/data1/kiro",
  "command": ["/mnt/data1/kiro/bin/feed-uucp"],
  "env": [
    {"name": "UUCP_DIR", "value": "/mnt/data1/zones/42/uucp/spool"},
